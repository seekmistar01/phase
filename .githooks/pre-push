#!/usr/bin/env bash
set -euo pipefail

echo "Running pre-push checks..."

# Git supplies refs on stdin after opening the remote connection. None of these
# checks need that stream, and detaching it keeps cargo/test children from
# inheriting hook input.
exec </dev/null

# Rust
echo "  [rust] cargo fmt --check"
cargo fmt --all -- --check

echo "  [rust] cargo clippy"
cargo clippy --workspace --all-targets --features engine/proptest -- -D warnings

echo "  [rust] mtgish ordering manifest coverage"
cargo test -p mtgish-import --test manifest_coverage every_list_field_is_in_ordering_manifest

echo "  [rust] card-data-validate release check"
cargo check --release --bin card-data-validate

echo "  [rust] parser combinator gate"
./scripts/check-parser-combinators.sh

echo "  [rust] engine parser tests"
PROPTEST_CASES="${PROPTEST_CASES:-4}" cargo test -p engine --features proptest parser::oracle::tests

echo "  [rust] phase-ai lib tests"
cargo test -p phase-ai --lib

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

echo "  [cards] oracle-gen"
cargo run --profile tool --bin oracle-gen --features cli -- data/ --stats --names-out "$tmpdir/card-names.json" > "$tmpdir/card-data.json"

echo "  [cards] card-data-validate"
cargo run --profile tool --bin card-data-validate -- "$tmpdir/card-data.json"

echo "  [cards] coverage-report"
mkdir -p "$tmpdir/data"
cp "$tmpdir/card-data.json" "$tmpdir/data/card-data.json"
cp "$tmpdir/card-names.json" "$tmpdir/data/card-names.json"
cargo run --profile tool --bin coverage-report -- "$tmpdir/data" --all > "$tmpdir/coverage-data.json"

echo "  [cards] coverage regression check"
./scripts/coverage-regression-check.sh \
  "https://pub-fc5b5c2c6e774356ae3e730bb0326394.r2.dev/preview/coverage-data.json" \
  "$tmpdir/coverage-data.json" \
  --fail-on-engine

# Frontend
echo "  [client] pnpm lint"
(cd client && pnpm lint)

echo "  [client] pnpm type-check"
(cd client && pnpm run type-check)

echo "All pre-push checks passed."
